{
    "kind": "collectionType",
    "collectionName": "inquiries",
    "info": {
        "singularName": "inquiry",
        "pluralName": "inquiries",
        "displayName": "Inquiry 咨询表单"
    },
    "options": {
        "draftAndPublish": false
    },
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "phone": {
            "type": "string",
            "required": true
        },
        "email": {
            "type": "email"
        },
        "message": {
            "type": "text"
        },
        "status": {
            "type": "enumeration",
            "enum": [
                "pending",
                "processing",
                "done"
            ],
            "default": "pending"
        }
    }
}